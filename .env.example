# ResolveOps AI Environment Configuration (.env.example)
# Copy to .env and fill in required runtime values.

APP_ENV=dev
LOG_LEVEL=info

# AI Provider (Amazon Bedrock)
AI_PROVIDER=bedrock
AWS_REGION=ap-south-1
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# OpenAI Configuration (Optional / Disabled by default)
OPENAI_FALLBACK_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Security & Secrets
JWT_SECRET=local-jwt-secret-dev-only
MCP_SERVICE_TOKEN=local-mcp-service-token-dev-only

# Database
POSTGRES_USER=resolveopsadmin
POSTGRES_PASSWORD=local-db-pass
POSTGRES_DB=resolveopsdb
DATABASE_URL=postgresql://resolveopsadmin:local-db-pass@postgres:5432/resolveopsdb

# Notifications / Email (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SENDER_EMAIL=
