APP_ENV=dev
LOG_LEVEL=info
AUTH_SERVICE_URL=http://auth-service:8000
GITHUB_INTELLIGENCE_SERVICE_URL=http://github-intelligence-service:8000
AZURE_INTELLIGENCE_SERVICE_URL=http://azure-intelligence-service:8000
AWS_INTELLIGENCE_SERVICE_URL=http://aws-intelligence-service:8000
AI_RCA_SERVICE_URL=http://ai-rca-service:8000
NOTIFICATION_SERVICE_URL=http://notification-service:8000
NEXT_PUBLIC_API_BASE_URL=/api

# Default storage account name 'local' triggers local filesystem storage fallback
STORAGE_ACCOUNT_NAME=local
BLOB_CONTAINER_NAME=local
LOCAL_STORAGE_DIR=/app/data/artifacts

# Add your mock secrets here for local development
JWT_SECRET=local-jwt-secret
SMTP_USER=local-smtp-user
SMTP_PASSWORD=local-smtp-password
AI_PROVIDER_API_KEY=local-ai-key
GITHUB_WEBHOOK_SECRET=local-gh-secret
DB_PASSWORD=local-db-pass
DATABASE_URL=postgresql://resolveopsadmin:local-db-pass@postgres:5432/resolveopsdb
