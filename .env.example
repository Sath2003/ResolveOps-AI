# ResolveOps AI Environment Variable Template (.env.example)
# DO NOT COMMIT REAL SECRETS OR MODIFIED .env TO REPOSITORY

APP_ENV=dev
LOG_LEVEL=info

# Service URLs (Internal Docker Compose network)
AUTH_SERVICE_URL=http://auth-service:8000
GITHUB_INTELLIGENCE_SERVICE_URL=http://github-intelligence-service:8000
AWS_INTELLIGENCE_SERVICE_URL=http://aws-intelligence-service:8000
AI_RCA_SERVICE_URL=http://ai-rca-service:8000
MCP_SERVER_URL=http://mcp-server-service:8000/mcp
DOCKER_EVIDENCE_ADAPTER_URL=http://docker-evidence-adapter:8000
NOTIFICATION_SERVICE_URL=http://notification-service:8000
API_GATEWAY_INTERNAL_URL=http://api-gateway-service:8000

# AI Provider Configuration
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_FALLBACK_ENABLED=false

AWS_REGION=ap-south-1
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_REQUEST_TIMEOUT_SECONDS=60
BEDROCK_MAX_RETRIES=2

# Feature Flags
MCP_RCA_ENABLED=true
AI_RCA_CHAT_ENABLED=true
LEGACY_GATEWAY_RAG_ENABLED=false

# RAG Knowledge Base Configuration
RAG_PROVIDER=bedrock_knowledge_base
BEDROCK_KNOWLEDGE_BASE_ID=
RAG_FAISS_FALLBACK_ENABLED=false

# Security & Tokens
MCP_SERVICE_TOKEN=local-mcp-service-token-dev-only
JWT_SECRET=local-jwt-secret-dev-only

# Security Allow-lists
ALLOWED_DOCKER_SERVICES=api-gateway-service,ai-rca-service,aws-intelligence-service,github-intelligence-service,mcp-server-service,docker-evidence-adapter,frontend,auth-service,notification-service
ALLOWED_CLOUDWATCH_LOG_GROUPS=/aws/ec2/resolveops,/aws/ecs/resolveops,/aws/lambda/resolveops

# Storage & Database (Development defaults)
STORAGE_ACCOUNT_NAME=local
BLOB_CONTAINER_NAME=local
LOCAL_STORAGE_DIR=/app/data/artifacts
POSTGRES_USER=resolveopsadmin
POSTGRES_PASSWORD=local-db-pass
POSTGRES_DB=resolveopsdb
DATABASE_URL=postgresql://resolveopsadmin:local-db-pass@postgres:5432/resolveopsdb
